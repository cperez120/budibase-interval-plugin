{
  "type": "component",
  "metadata": {
    "svelteMajor": 5
  },
  "schema": {
    "name": "Interval",
    "friendlyName": "Interval",
    "description": "Set time interval to refresh data provider automatically",
    "icon": "Stopwatch",
    "settings": [
      {
        "type": "boolean",
        "key": "isActive",
        "label": "Timer Active?",
        "defaultValue": true,
        "required": true
      },
      {
        "type": "number",
        "key": "interval",
        "label": "Interval (in seconds)",
        "defaultValue": 10,
        "min": 1,
        "required": true
      },
      {
        "type": "boolean",
        "key": "display",
        "label": "Display component in frontend",
        "defaultValue": true
      },
       {
        "type": "boolean",
        "key": "displayIcon",
        "label": "Display Icon before text",
        "defaultValue": true,
        "dependsOn": {
          "setting": "display",
          "value": true
        }
      },
      {
        "type": "text",
        "key": "text",
        "label": "Text to display",
        "defaultValue": "Interval",
        "dependsOn": {
          "setting": "display",
          "value": true
        }
      },
      {
        "type": "event",
        "key": "trigger",
        "label": "On interval"
      }
    ]
  }
}